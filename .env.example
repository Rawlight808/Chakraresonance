# --- Frontend (Vite) ---
# Public CDN / object-storage base for all audio + screensavers.
# Cloudflare R2 with custom domain on chakraresonance.com:
VITE_MEDIA_PUBLIC_BASE=https://media.chakraresonance.com

# --- Uploader (scripts/upload-media.mjs) — never shipped to the browser ---
# Cloudflare R2 S3-compatible API credentials.
# Get them at: R2 dashboard → "Manage R2 API Tokens" → create token with read+write to your bucket.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=chakra-media

# Optional overrides for the uploader:
# R2_AUDIO_DIR=/Users/micah/Desktop/NEW CHAKRA MUSIC SUNO /432Hz
# R2_SCREENSAVERS_DIR=/path/to/screensavers

# --- Legacy Supabase fallbacks (only used if VITE_MEDIA_PUBLIC_BASE is unset) ---
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
